{
  "framework": null,
  "buildCommand": "composer install --no-dev --optimize-autoloader --no-interaction",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-community/php@0.7.2"
    }
  },
  "routes": [
    { "src": "/manifest\\.json", "dest": "/public/manifest.json" },
    { "src": "/sw\\.js",         "dest": "/public/sw.js"         },
    { "src": "/offline\\.html",  "dest": "/public/offline.html"  },
    { "src": "/favicon\\.ico",   "dest": "/public/favicon.ico"   },
    { "src": "/icon\\.svg",      "dest": "/public/icon.svg"      },
    { "src": "/icons/(.*)",      "dest": "/public/icons/$1"      },
    { "src": "/(.*)",            "dest": "/api/index.php"        }
  ]
}
